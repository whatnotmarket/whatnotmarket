# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ahrefs
/ahrefs

# docs
/docs

# reports
/reports

# indexnow
indexnow_payload_*.json

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local caches and binaries
.npm-cache/
codex-local.exe
*.exe
supabase/.temp/
supabase/.cache/
supabase/.branches/
supabase/.config
supabase/.local/*
supabase/.metadata/*

# Private operational SQL/scripts (keep migrations public)
supabase/scripts/private/**
*.sql.local
*.dump
*.pgdump

# OS-specific
Thumbs.db
Desktop.ini
ehthumbs.db
Icon?

# Editors / IDE
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# Logs
logs/
*.log
npm-debug.log*
yarn-*.log*
pnpm-debug.log*

# Build / Cache
dist/
.turbo/
.parcel-cache
.swc/
.cache/
.eslintcache

# Temporary
tmp/
temp/
*.tmp
